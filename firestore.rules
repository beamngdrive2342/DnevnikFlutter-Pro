rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Коды для вступления
    match /class_codes/{code} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Классы
    match /classes/{classId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.token.email == request.resource.data.adminEmail;
      allow update, delete: if request.auth != null && request.auth.token.email == resource.data.adminEmail;
      
      // Подколлекция участников класса (BOLA fix)
      match /members/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
      
      // Подколлекция домашних заданий
      match /homework/{hwId} {
        allow read, write: if request.auth != null && (
          get(/databases/$(database)/documents/classes/$(classId)).data.adminEmail == request.auth.token.email ||
          exists(/databases/$(database)/documents/classes/$(classId)/members/$(request.auth.uid))
        );
      }
    }
  }
}
